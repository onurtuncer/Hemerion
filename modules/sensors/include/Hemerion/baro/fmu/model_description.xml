  FMI 2.0 model description for the barometer hardware simulator FMU
  (Hemerion/baro/fmu/fmu_main.cpp). This FMU has no FMI-level outputs: its
  only effect is a UDP side channel (Hemerion barometer raw-sample frames
  sent on every fmi2DoStep, sample_rate_hz frames per simulated second), so
  <Outputs> in ModelStructure is intentionally empty. The guid below must
  match kExpectedGuid in fmu_main.cpp exactly.

  Note: "double hyphen" sequences are illegal inside XML comments (and make
  strict parsers such as fmi4c's ezxml reject the whole document), so the
  repo's usual comment dash style is avoided in this file.
-->
<fmiModelDescription
    fmiVersion="2.0"
    modelName="HemerionBaroSimulator"
    guid="{8FD10411-5024-4F27-B704-8251CE8D3FEF}"
    description="Truth-altitude-to-compensated-pressure-counts barometer hardware simulator for SWIL/HIL co-simulation"
    generationTool="hand-written (see fmu_main.cpp header comment)"
    variableNamingConvention="flat">

  <CoSimulation
      modelIdentifier="hemerion_baro_fmu"
      canHandleVariableCommunicationStepSize="true"
      canGetAndSetFMUstate="false"
      canSerializeFMUstate="false"
      providesDirectionalDerivative="false"/>

  <ModelVariables>
    <!--
      True geometric altitude above mean sea level. The noise model maps it
      through the ICAO Standard Atmosphere (troposphere + isothermal
      stratosphere layers) to the ambient pressure and temperature the part
      would sense.
    -->
    <ScalarVariable name="h_m" valueReference="0" causality="input" variability="continuous">
      <Real start="0.0"/>
    </ScalarVariable>
    <!--
      Sensor output data rate. Each fmi2DoStep emits round(step * rate)
      frames (at least one); the truth input is zero-order-held across the
      step, so sub-step frames differ in noise draw and timestamp only.
    -->
    <ScalarVariable name="sample_rate_hz" valueReference="1" causality="parameter" variability="tunable">
      <Real start="50.0"/>
    </ScalarVariable>
  </ModelVariables>

  <ModelStructure>
    <!-- No <Outputs/> entries: this FMU's effect is the UDP side channel in fmi2DoStep, not FMI variable exchange. -->
  </ModelStructure>

</fmiModelDescription>
