  FMI 2.0 model description for the GPS UBX hardware simulator FMU
  (Hemerion/gps/fmu/fmuMain.cpp). This FMU has no FMI-level outputs: its
  only effect is a UDP side channel (a UBX-NAV-PVT frame sent on every
  fmi2DoStep), so <Outputs> in ModelStructure is intentionally empty. The
  guid below must match kExpectedGuid in fmuMain.cpp exactly.

  Note: "double hyphen" sequences are illegal inside XML comments (and make
  strict parsers such as fmi4c's ezxml reject the whole document), so the
  repo's usual comment dash style is avoided in this file.
-->
<fmiModelDescription
    fmiVersion="2.0"
    modelName="HemerionGpsUbxSimulator"
    guid="{8C5D3A1F-2E9B-4D67-A4C8-5B0E9F3D7A21}"
    description="Truth-state-to-UBX-NAV-PVT GPS hardware simulator for SWIL/HIL co-simulation"
    generationTool="hand-written (see fmuMain.cpp header comment)"
    variableNamingConvention="flat">

  <CoSimulation
      modelIdentifier="hemerion_gps_fmu"
      canHandleVariableCommunicationStepSize="true"
      canGetAndSetFMUstate="false"
      canSerializeFMUstate="false"
      providesDirectionalDerivative="false"/>

  <ModelVariables>
    <ScalarVariable name="latitude_deg" valueReference="0" causality="input" variability="continuous">
      <Real start="0.0"/>
    </ScalarVariable>
    <ScalarVariable name="longitude_deg" valueReference="1" causality="input" variability="continuous">
      <Real start="0.0"/>
    </ScalarVariable>
    <ScalarVariable name="altitude_m" valueReference="2" causality="input" variability="continuous">
      <Real start="0.0"/>
    </ScalarVariable>
    <ScalarVariable name="ground_speed_mps" valueReference="3" causality="input" variability="continuous">
      <Real start="0.0"/>
    </ScalarVariable>
    <ScalarVariable name="course_deg" valueReference="4" causality="input" variability="continuous">
      <Real start="0.0"/>
    </ScalarVariable>
    <!--
      NED truth velocity, the natural output set of a 6-DoF plant (e.g. Aetherion's TwoStageRocket
      FMU). Once any of these is written, ground_speed_mps/course_deg above are ignored and the
      emitted speed-over-ground and course are derived from v_north/v_east instead. v_down_mps is
      accepted for interface completeness but the NAV-PVT velD field is currently still encoded as 0
      (GpsFix carries no vertical velocity yet).
    -->
    <ScalarVariable name="v_north_mps" valueReference="5" causality="input" variability="continuous">
      <Real start="0.0"/>
    </ScalarVariable>
    <ScalarVariable name="v_east_mps" valueReference="6" causality="input" variability="continuous">
      <Real start="0.0"/>
    </ScalarVariable>
    <ScalarVariable name="v_down_mps" valueReference="7" causality="input" variability="continuous">
      <Real start="0.0"/>
    </ScalarVariable>
  </ModelVariables>

  <ModelStructure>
    <!-- No <Outputs/> entries: this FMU's effect is the UDP side channel in fmi2DoStep, not FMI variable exchange. -->
  </ModelStructure>

</fmiModelDescription>
