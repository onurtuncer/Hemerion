{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 26, "patch": 0 },

  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "cross-base",
      "hidden": true,
      "inherits": "base",
      "description": "Cross-compiled for Cortex-M (STM32H7/F4) via arm-none-eabi-gcc",
      "toolchainFile": "${sourceDir}/toolchains/arm-none-eabi.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "HEMERION_BUILD_FMU": "OFF"
      }
    },
    {
      "name": "native-base",
      "hidden": true,
      "inherits": "base",
      "description": "Native host build (Linux GCC/Clang or Windows MSVC). No toolchain file is forced here so the same preset name works on every CI runner — toolchains/x86_64-linux.cmake and toolchains/x86_64-windows-msvc.cmake remain available for callers who want their stricter flags applied explicitly.",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF"
      }
    },

    {
      "name": "renode-h743",
      "inherits": "cross-base",
      "displayName": "Renode SWIL — STM32H743",
      "description": "Firmware cross-compiled for the Nucleo-H743 BSP, run under Renode SWIL or flashed HWIL",
      "cacheVariables": {
        "HEMERION_BSP": "stm32h743_nucleo"
      }
    },
    {
      "name": "cross-stm32f446",
      "inherits": "cross-base",
      "displayName": "Cross — STM32F446 custom (ECS gateway)",
      "description": "Firmware cross-compiled for the custom STM32F446 ECS gateway BSP. Build only — see tests/README.md CI matrix.",
      "cacheVariables": {
        "HEMERION_BSP": "stm32f446_custom"
      }
    },
    {
      "name": "fmu-native",
      "inherits": "native-base",
      "displayName": "FMU (native)",
      "description": "Builds every module as an x86 FMI 2.0 shared library for Aetherion co-simulation",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "HEMERION_BSP": "native_linux",
        "HEMERION_BUILD_FMU": "ON",
        "HEMERION_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "examples-native",
      "inherits": "fmu-native",
      "displayName": "Examples (native)",
      "description": "fmu-native plus the host-side end-to-end examples (Ecos co-simulation of Aetherion + Hemerion FMUs)",
      "cacheVariables": {
        "HEMERION_BUILD_EXAMPLES": "ON"
      }
    },
    {
      "name": "test-native",
      "inherits": "native-base",
      "displayName": "Unit + integration tests (native)",
      "description": "Native host build with module test binaries; cmake/sanitizers.cmake enables ASan/UBSan here on supported compilers",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "HEMERION_BSP": "native_linux",
        "HEMERION_BUILD_FMU": "OFF",
        "HEMERION_BUILD_TESTS": "ON",
        "HEMERION_BUILD_SIM": "ON"
      }
    },
    {
      "name": "test-swil",
      "inherits": "renode-h743",
      "displayName": "SWIL tests (Renode)",
      "description": "Cross-compiled STM32H743 firmware plus the tests/swil pytest harness, run under Renode via pyrenode3",
      "cacheVariables": {
        "HEMERION_BUILD_TESTS": "ON"
      }
    }
  ],

  "buildPresets": [
    { "name": "renode-h743", "configurePreset": "renode-h743" },
    { "name": "cross-stm32f446", "configurePreset": "cross-stm32f446" },
    { "name": "fmu-native", "configurePreset": "fmu-native" },
    { "name": "examples-native", "configurePreset": "examples-native" },
    { "name": "test-native", "configurePreset": "test-native" },
    { "name": "test-swil", "configurePreset": "test-swil" }
  ],

  "testPresets": [
    {
      "name": "test-native",
      "configurePreset": "test-native",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    },
    {
      "name": "fmu-native",
      "configurePreset": "fmu-native",
      "filter": { "include": { "label": "fmu" } },
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "ignore", "stopOnFailure": false }
    },
    {
      "name": "test-swil",
      "configurePreset": "test-swil",
      "filter": { "include": { "label": "swil" } },
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    }
  ]
}
